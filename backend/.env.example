PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/followup_dashboard

# Secret used to sign login tokens (JWT). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Initial admin account, created on first startup if no admin exists.
ADMIN_NAME=Venkat Ramanan Kalyanaraman
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=kvr@focasedu.com

# Zoho CRM write-back (optional). Without these, status/note changes are saved
# locally only. Fill in to sync changes back to Zoho.
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
# ZOHO_API_URL=https://www.zohoapis.in
# ZOHO_MODULE=Tasks

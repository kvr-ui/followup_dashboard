PORT=3000
MONGO_URI=mongodb://127.0.0.1:27017/followup_dashboard

# Secret used to sign login tokens (JWT). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# Initial admin account, created on first startup if no admin exists.
ADMIN_NAME=Venkat Ramanan Kalyanaraman
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=kvr@focasedu.com

# --- WhatsApp / WATI ---------------------------------------------------------
WATI_API_URL=https://live-mt-server.wati.io/xxxxx
WATI_TOKEN=

# --- Campaigns ---------------------------------------------------------------
# The public origin of THIS server. Campaign links are rewritten to
# <PUBLIC_BASE_URL>/r/<code> so clicks can be attributed to a contact.
#
# Without it, campaigns still send — but every link goes out untracked, and clicks
# are the ONLY real intent signal WhatsApp gives you (there is no link-tap event in
# the WhatsApp Business API, in WATI or anywhere else). Set this.
PUBLIC_BASE_URL=https://dashboard.focasedu.com

# Shared secret appended to the WATI webhook URL:
#   https://<host>/webhook/wati?token=<this>
# WATI's webhook config offers a URL field and nothing else — no signing secret, no
# custom headers — so this is the only protection available. Without it, anyone who
# guesses the path can post fake delivery and read events.
WATI_WEBHOOK_TOKEN=

# Where a dead/unknown short link sends someone. They clicked in good faith.
# CAMPAIGN_FALLBACK_URL=https://focasedu.com

# Reads are timestamped in UTC. "Do they read at 9am?" is a question about THEIR
# morning — get this wrong and the best-send-time chart is off by 5.5 hours.
# CAMPAIGN_TIMEZONE=Asia/Kolkata

# Conversation prices, for the cost estimates. Meta bills per 24h conversation and a
# marketing one costs ~7x a utility one in India. These are list prices — WATI resells
# at its own rate, so treat every cost figure in the dashboard as an estimate.
# WA_RATE_MARKETING=0.78
# WA_RATE_UTILITY=0.115
# WA_RATE_AUTH=0.115
# WA_CURRENCY=INR

# Don't message the same person twice within N hours, whatever the campaign says.
# One block hurts more than one extra send earns. 0 = off.
# CAMPAIGN_FATIGUE_HOURS=0

# The send worker. CAMPAIGN_JOBS_ENABLED=false switches sending off entirely.
# CAMPAIGN_TICK_SECONDS=15
# CAMPAIGN_SEQUENCE_MINUTES=10
# CAMPAIGN_JOBS_ENABLED=true

# How long after a send a status webhook can still be attributed to it, when WATI
# doesn't return a message id and we have to fall back to matching on phone number.
# CAMPAIGN_ATTRIBUTION_HOURS=72
# CAMPAIGN_REPLY_ATTRIBUTION_DAYS=14

# Zoho CRM write-back (optional). Without these, status/note changes are saved
# locally only. Fill in to sync changes back to Zoho.
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# ZOHO_REFRESH_TOKEN=
# ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
# ZOHO_API_URL=https://www.zohoapis.in
# ZOHO_MODULE=Tasks
